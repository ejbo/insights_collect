# =============================================================================
# Insights Collect — backend env
# Copy to `.env` for local裸装；Docker compose 默认从 `.env` 读
# =============================================================================

# ---------- App ----------
APP_NAME=insights-collect
APP_ENV=dev
LOG_LEVEL=INFO

# ---------- Database ----------
# 本地裸装：localhost:5432；Docker：postgres:5432（compose 内 hostname）
DATABASE_URL=postgresql+asyncpg://insights:insights@localhost:5432/insights_collect
# 同步 URL 给 Alembic 与 LangGraph PostgresSaver
DATABASE_URL_SYNC=postgresql://insights:insights@localhost:5432/insights_collect

# ---------- Storage paths ----------
STORAGE_DIR=./storage
REPORTS_DIR=./storage/reports
PDFS_DIR=./storage/pdfs
OUTLINES_DIR=./storage/outlines

# ---------- LLM / Search Providers ----------
# 至少配 ANTHROPIC_API_KEY 才能跑通；其他可逐家加，Day-1 缺哪个 provider 自动跳过
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=

# ---------- Embedding ----------
# 用于专家 / 观点 / 主题向量化、聚类、跨源去重
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---------- LangSmith (optional, agent tracing) ----------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insights-collect

# ---------- Cost guards (per report run) ----------
MAX_TOKENS_PER_RUN=2000000
MAX_PROVIDER_CALLS_PER_RUN=300
COST_CAP_USD_PER_RUN=10.0
MAX_REFLECTION_ROUNDS=3

# ---------- Per-call timeouts ----------
# Wraps every provider.search() in MultiSearch with this; on timeout the call is
# marked failed but other in-flight calls continue.
PROVIDER_CALL_TIMEOUT_S=90
# Used by the /settings smoke-test endpoint
SMOKE_CALL_TIMEOUT_S=60

# ---------- Frontend ----------
FRONTEND_URL=http://localhost:3000
